# ---- Base de données ----
# Chemin vers la base SQLite des commandes (relatif à la racine du projet)
DB_PATH=data/raw/orders.db

# ---- LLM ----
# Backend à utiliser : "api" (API Mistral hébergée) ou "local" (modèle quantisé HF)
LLM_BACKEND=api

# Backend API (Mistral hébergé)
MISTRAL_API_KEY=replace_me
MISTRAL_MODEL=mistral-small-latest

# Backend local (HF Transformers, quantisation FP8)
LOCAL_MODEL_ID=mistralai/Ministral-3-14B-Instruct-2512
LOCAL_DEVICE_MAP=auto

# ---- Classification d'intention ----
# Stratégie de classification avant le nœud SQL
# "llm"      : appel LLM structuré Pydantic (précis, consomme des tokens)
# "semantic" : similarité cosinus sur embeddings multilingues (rapide, local)
CLASSIFIER_STRATEGY=llm

# Numéro du conseiller humain affiché pour les demandes d'action sur commande
ADVISOR_PHONE=06.07.06.07.06

# ---- Environnement ----
ENV=development  # development | staging | production
LOG_LEVEL=INFO
TRANSFORMERS_VERBOSITY=error
