# ---- Base de données ----
# Chemin vers la base SQLite des commandes (relatif à la racine du projet)
DB_PATH=data/raw/orders.db

# ---- LLM ----
# Backend à utiliser : "api" (API Mistral hébergée) ou "local" (modèle quantisé HF)
LLM_BACKEND=api

# Backend API (Mistral hébergé)
MISTRAL_API_KEY=replace_me
MISTRAL_MODEL=mistral-small-latest

# Backend local (HF Transformers, quantisation FP8)
LOCAL_MODEL_ID=mistralai/Ministral-3-14B-Instruct-2512
LOCAL_DEVICE_MAP=auto

# ---- Session utilisateur (authentification simulée) ----
# user_id de la table users avec lequel le bot croit dialoguer
SESSION_USER_ID=1

# ---- Environnement ----
ENV=development  # development | staging | production
LOG_LEVEL=INFO
